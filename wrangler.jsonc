{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "quadsignals",
  "compatibility_date": "2026-04-03",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "quadsignals-production",
      "database_id": "f01934e5-44b8-47df-bac2-8d79213cd476"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "STOCK_CACHE",
      "id": "4105984439ae430ba5c8ee2e50b90e26"
    }
  ]
}
