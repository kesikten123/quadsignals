{
  "name": "quadsignals",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:sandbox": "wrangler pages dev dist --d1=quadsignals-production --local --ip 0.0.0.0 --port 3000",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name quadsignals",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply quadsignals-production --local",
    "db:seed": "wrangler d1 execute quadsignals-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute quadsignals-production --local"
  },
  "dependencies": {
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.1",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
